# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# capacitor
/android/
/ios/
/.capacitor/
/.api-backup/
/.icon-backup/
/.chat-backup/
/.dynamic-routes-backup/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/debug.log

# env files (can opt-in for committing if needed)
.env*
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database backups
/backups/
*.sql
*.sql.gz

# large archive files (exceed GitHub 100MB limit)
*.zip
.vercel

# Sentry Config File
.env.sentry-build-plugin

# e2e auth (cookie di sessione — non versionare)
tests/e2e/.auth/

# report e cache generati
playwright-report/
test-results/
.vitest-cache/

# supabase CLI temp
supabase/.temp/

# storico AI locale (non versionare)
ai_memory/

# log debug
debug-*.log

# Cursor MCP (può contenere chiavi)
.cursor/mcp.json

# Playwright auth accidentale in root
/athlete-auth.json
/admin-auth.json
/pt-auth.json

# Segreti MCP locali (copia da mcp.secrets.env.example)
.cursor/mcp.secrets.env

# Documentazione e note di progetto (solo locale; non su GitHub)
/Cervello/
/DOCUMENTAZIONE/
/docs/
/audit/
/dashboard-trainer-perf/
verification-report.json
