# =====================================================
# 🗃️ Database Configuration (ORM: Prisma / Drizzle)
# =====================================================

# Connection pooling URL - per connessioni standard dell'app (migliori performance)
DATABASE_URL="postgresql://postgres.your-project-id:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL - per migrazioni e operazioni amministrative
DIRECT_URL="postgresql://postgres.your-project-id:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres"

# =====================================================
# 🔔 Push Notifications (VAPID Keys)
# =====================================================

# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@22club.it

# =====================================================
